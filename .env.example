# ============================================================================
# Full AIOS — Stack Local Docker
# ----------------------------------------------------------------------------
# Como usar:
#   1) cp .env.example .env
#   2) Preencher cada variavel abaixo (procure por __CHANGE_ME__)
#   3) Criar diretorio de dados: mkdir -p Full_AIOS_Data/leadgen/{bronze,silver,gold}
#   4) docker compose up -d
# ============================================================================


# ---- PostgreSQL local (servico `postgres` do compose) ----------------------
# Senha do usuario `fulled` no postgres local. Usado por:
#   - servico postgres (POSTGRES_PASSWORD na imagem postgres:17)
#   - servico migrator (PGPASSWORD ao rodar psql)
#   - servico fastapi (interpolado no DATABASE_URL)
#   - servico polling-container (interpolado no DATABASE_URL)
POSTGRES_PASSWORD=__CHANGE_ME__local_dev_pwd

# DATABASE_URL completo para consumo dos containers
# Host = `postgres` (nome do servico na rede `fulled-local`)
# Porta interna do postgres = 5432 (independente do mapeamento host:5432)
DATABASE_URL=postgres://fulled:__CHANGE_ME__local_dev_pwd@postgres:5432/fulled


# ---- Multica REST API (consumido pelo polling-container) -------------------
# Multica roda FORA do nosso compose (make selfhost separado), em localhost:8080.
# De dentro do container do polling, o host resolve via host.docker.internal.
MULTICA_API_URL=http://host.docker.internal:8080

# Personal Access Token gerado no Multica (Settings > Developer > Tokens)
# Necessario para o polling-container criar issues via REST API.
MULTICA_PAT_TOKEN=__CHANGE_ME__multica_pat_here

# UUID do workspace no Multica — header X-Workspace-ID obrigatorio em POST /api/issues.
# Como obter:
#   Opcao 1 (UI):  Multica > Settings > Workspace > General (campo "Workspace ID")
#   Opcao 2 (psql): docker exec multica-postgres psql -U multica -c "SELECT id, name FROM workspaces;"
#   Opcao 3 (curl): curl -H "Authorization: Bearer mul_..." http://localhost:8080/api/workspaces
MULTICA_WORKSPACE_ID=__CHANGE_ME__11111111-1111-1111-1111-111111111111

# Nome do agente que sera acionado no Multica quando o polling detectar uma task pendente.
# Valor padrao: kw_validator (Agents 2+3 do pipeline LeadGen).
AGENT_NAME=kw_validator


# ---- LLM providers (consumido pelos agentes CrewAI) ------------------------
# OpenRouter — recomendado para flash/cost models
# Obter em: https://openrouter.ai/keys
OPENROUTER_API_KEY=__CHANGE_ME__sk-or-v1-xxxx

# Gemini direto — opcional (alternativa ao OpenRouter)
# Obter em: https://aistudio.google.com/apikey
GEMINI_API_KEY=__CHANGE_ME__AIza...


# ---- Google Ads API (consumido pelo agente kw_research) --------------------
# Credenciais OAuth + Developer Token para Keyword Planner.
# Obter em: https://ads.google.com/aw/apicenter
# Tutorial: https://developers.google.com/google-ads/api/docs/oauth/cloud-project
GOOGLE_ADS_DEVELOPER_TOKEN=__CHANGE_ME__
GOOGLE_ADS_CLIENT_ID=__CHANGE_ME__.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=__CHANGE_ME__
GOOGLE_ADS_REFRESH_TOKEN=__CHANGE_ME__
# Login customer ID = MCC (parent) account; Customer ID = conta-filha (sem hyphens)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=__CHANGE_ME__1234567890
GOOGLE_ADS_CUSTOMER_ID=__CHANGE_ME__0987654321


# ---- Frontend (build-time variables) ---------------------------------------
# URL que o frontend usa para chamar a FastAPI.
# Em dev local atras do nginx, o frontend acessa /api e o vite proxy redireciona.
# Para o build de producao no container nginx, apontamos diretamente:
VITE_API_URL=http://localhost:8000
